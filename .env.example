# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=1456
DATABASE_NAME=journal_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password_here

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Email Domain Restriction
# Set to true to only allow registration from specific email domains
RESTRICT_EMAIL_DOMAINS=false
# Comma-separated list of allowed domains (only used when RESTRICT_EMAIL_DOMAINS=true)
ALLOWED_EMAIL_DOMAINS=example.com,mycompany.org

# Ollama OCR Configuration
# Hostname used to reach the Ollama process running on the host machine.
# On Docker Desktop (Mac/Windows): host.docker.internal works automatically.
# On Linux with standard Docker Engine: use the host's LAN IP (e.g. 192.168.1.50)
# or add `extra_hosts: ["host.docker.internal:host-gateway"]` to docker-compose.yml
# and keep this value as host.docker.internal.
OLLAMA_HOST=host.docker.internal
# Port the local Ollama instance is listening on
OLLAMA_PORT=11434
# Vision model to use for OCR transcription (e.g. llama3.2-vision, minicpm-v)
# Leave empty to disable automatic transcription on upload
OCR_MODEL=
# Generative model used for text responses, needs to support tool calling for the agentic loop (e.g. llama3.2, mistral)
# Leave empty to disable generate() calls and the improve_transcription() agentic loop
RESPONSE_MODEL=
# Embedding model used for vector embeddings (e.g. nomic-embed-text, mxbai-embed-large, bge-m3)
# Leave empty to disable embed() calls
EMBEDDING_MODEL=
# Dimensionality of the embedding vectors produced by EMBEDDING_MODEL.
# Must match the vector(N) column dimension in the database schema (default: 1024 for bge-m3).
# If you change this, you must also rebuild the database container or alter the column type manually.
EMBEDDING_DIM=1024

# Agentic Cleanup Configuration
# Maximum number of tool-calling iterations the agent may perform before a forced abort
AGENT_MAX_ITERATIONS=10
# Context window size in tokens for the agent's chat calls.
# Larger values improve the agent's ability to reason over long entries and tool
# results but increase VRAM usage. Must not exceed the model's trained maximum.
AGENT_CONTEXT_SIZE=8192
# Prompt batch size for agent chat calls. Lower values reduce memory pressure
# at the cost of slower prompt evaluation. Generation speed is unaffected.
AGENT_BATCH_SIZE=64
