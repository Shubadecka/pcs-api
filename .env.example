# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=1456
DATABASE_NAME=journal_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password_here

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Email Domain Restriction
# Set to true to only allow registration from specific email domains
RESTRICT_EMAIL_DOMAINS=false
# Comma-separated list of allowed domains (only used when RESTRICT_EMAIL_DOMAINS=true)
ALLOWED_EMAIL_DOMAINS=example.com,mycompany.org

# Ollama OCR Configuration
# Hostname used to reach the Ollama process running on the host machine.
# On Docker Desktop (Mac/Windows): host.docker.internal works automatically.
# On Linux with standard Docker Engine: use the host's LAN IP (e.g. 192.168.1.50)
# or add `extra_hosts: ["host.docker.internal:host-gateway"]` to docker-compose.yml
# and keep this value as host.docker.internal.
OLLAMA_HOST=host.docker.internal
# Port the local Ollama instance is listening on
OLLAMA_PORT=11434
# Vision model to use for OCR transcription (e.g. llama3.2-vision, minicpm-v)
# Leave empty to disable automatic transcription on upload
OCR_MODEL=
# Generative model used for text responses (e.g. llama3.2, mistral)
# Leave empty to disable generate() calls
RESPONSE_MODEL=
# Embedding model used for vector embeddings (e.g. nomic-embed-text, mxbai-embed-large)
# Leave empty to disable embed() calls
EMBEDDING_MODEL=
